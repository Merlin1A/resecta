    "eula_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Before You Begin"
          }
        }
      }
    },
    "eula_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to Resecta.\n\nThis app helps you redact sensitive information in PDFs and images. All processing happens entirely on your device — the app collects no data and makes no network requests of its own. Links you tap open in Safari or Mail.\n\nImportant: This app is provided \"as is\" without warranty of any kind. Automated redaction tools can miss sensitive content. You are responsible for verifying that all sensitive information has been properly redacted before sharing any document.\n\nBy tapping \"I Agree,\" you agree to the End-User License Agreement and acknowledge the Privacy Policy."
          }
        }
      }
    },
    "eula_agree" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I Agree"
          }
        }
      }
    },
    "pre_export_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Have You Verified Your Redactions?"
          }
        }
      }
    },
    "pre_export_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app provides tools to assist with redaction but cannot guarantee complete removal of all sensitive information.\n\nBefore sharing, please confirm: you have reviewed every page, all sensitive text, images, and metadata have been redacted, and the output meets your requirements."
          }
        }
      }
    },
    "pre_export_confirm" : {
      "extractionState" : "manual",
